# Test Environment Variables Example
# Copy this file to .env.test and fill in your test credentials

BASE_URL=http://localhost:3001

# Test Credentials
TEST_USER_EMAIL=your-test-email@example.com
TEST_USER_PASSWORD=your-test-password

# Delhivery (leave blank to test the "not configured" error path)
DELHIVERY_API_TOKEN=
DELHIVERY_API_BASE_URL=https://staging-express.delhivery.com
# Token used to sign/verify Delhivery webhook payloads in tests
DELHIVERY_WEBHOOK_TOKEN=test-delhivery-webhook-token

# Bearer token used for protected internal/admin job routes in tests
INTERNAL_JOB_TOKEN=test-internal-job-token
